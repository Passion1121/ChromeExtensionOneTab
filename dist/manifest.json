{
  "manifest_version": 3,
  "name": "AetherTabs",
  "version": "1.0.0",
  "description": "A premium tab control workspace.",
  "minimum_chrome_version": "114",
  "permissions": ["tabs"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Open AetherTabs",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_popup": "popup.html"
  }
}
