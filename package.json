{
  "name": "tabdebt-manager",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "sync:runtime": "bash scripts/sync-dist-to-root.sh",
    "build:runtime": "npm run build && npm run sync:runtime",
    "package:webstore": "npm run build:runtime && bash scripts/package-webstore.sh",
    "package:webstore:dist": "bash scripts/package-webstore.sh"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/node": "^25.3.3",
    "@types/react": "^18.3.8",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
